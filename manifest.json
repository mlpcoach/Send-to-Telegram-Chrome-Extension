{
  "name": "Sanctum Send — Multi-Bot Telegram Sender",
  "version": "2.0.0",
  "description": "Send web content to any of your Telegram bots. Multi-bot, file attachments, right-click menus.",
  "action": {
    "default_icon": "tg.png",
    "default_title": "Sanctum Send",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "128": "tg.png"
  },
  "options_page": "options.html",
  "permissions": [
    "tabs",
    "contextMenus",
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "https://api.telegram.org/*"
  ],
  "content_scripts": [{
    "matches": ["http://*/*", "https://*/*"],
    "js": ["content_script.js"]
  }],
  "manifest_version": 3
}
